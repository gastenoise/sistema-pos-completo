{
  "name": "SmtpConfig",
  "type": "object",
  "properties": {
    "business_id": {
      "type": "string",
      "description": "Associated business ID"
    },
    "host": {
      "type": "string",
      "description": "SMTP server host"
    },
    "port": {
      "type": "number",
      "description": "SMTP server port",
      "default": 587
    },
    "username": {
      "type": "string",
      "description": "SMTP username"
    },
    "password": {
      "type": "string",
      "description": "SMTP password"
    },
    "encryption": {
      "type": "string",
      "enum": [
        "none",
        "tls",
        "ssl"
      ],
      "default": "tls",
      "description": "Encryption type"
    },
    "from_name": {
      "type": "string",
      "description": "Sender name"
    },
    "from_email": {
      "type": "string",
      "description": "Sender email address"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "business_id",
    "host",
    "port",
    "username",
    "from_email"
  ]
}