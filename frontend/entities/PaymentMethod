{
  "name": "PaymentMethod",
  "type": "object",
  "properties": {
    "business_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "cash",
        "debit",
        "credit",
        "mercado_pago",
        "transfer",
        "other"
      ],
      "default": "cash"
    },
    "color": {
      "type": "string",
      "description": "Hex color for UI display"
    },
    "icon": {
      "type": "string",
      "description": "Icon name for the payment method",
      "default": "CreditCard"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "is_default": {
      "type": "boolean",
      "default": false,
      "description": "Whether this is the default payment method"
    },
    "requires_reference": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "business_id",
    "name",
    "type"
  ]
}