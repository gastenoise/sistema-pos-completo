{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "esnext"
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "src/api/**/*.test.ts",
    "src/components/**/*.test.ts",
    "src/hooks/**/*.test.ts",
    "src/lib/**/*.test.ts",
    "src/modules/**/hooks/**/*.test.ts",
    "src/modules/**/utils/**/*.test.ts",
    "tests/**/*.ts"
  ]
}
