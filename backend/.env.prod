APP_NAME="Sistema POS"
APP_ENV=production
APP_KEY=base64:W+HyWX7UWDODkPr5FV/Kgi0axaqRcs5GWJ0b4jY60/Q=
APP_DEBUG=false
APP_URL=https://sistema-pos-completo.onrender.com

# Logging
LOG_CHANNEL=stderr
LOG_LEVEL=info

# Database (REPLACE these with your DB provider details)
DB_CONNECTION=mysql
DB_HOST=REPLACE_WITH_DB_HOST           # e.g. mydb.cluster.provider.com
DB_PORT=3306
DB_DATABASE=openventa
DB_USERNAME=REPLACE_WITH_DB_USER
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD

# Cache / Sessions / Queue
# Default to file-based to avoid depending on Redis unless you provision it.
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# If you provision Redis, uncomment and fill these:
# REDIS_CLIENT=predis
# REDIS_HOST=REPLACE_WITH_REDIS_HOST
# REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD_OR_null
# REDIS_PORT=6379

# Filesystem
FILESYSTEM_DISK=local

# Mail
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="Sistema POS"

# Third-party / App-specific
MERCADOPAGO_ACCESS_TOKEN=TEST-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# SEPA dataset URLs (kept as-is)
SEPA_URL_LUNES=https://datos.produccion.gob.ar/dataset/6f47ec76-d1ce-4e34-a7e1-621fe9b1d0b5/resource/0a9069a9-06e8-4f98-874d-da5578693290/download/sepa_lunes.zip
