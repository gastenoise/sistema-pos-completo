```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Environment variables
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs and temporary files
*.log
*.tmp
*.temp

# Coverage reports
coverage/
htmlcov/
.coverage

# Python artifacts (if any Python files detected in project)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Compressed files
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.rar
*.7z

# OS generated files
.DS_Store
Thumbs.db
```